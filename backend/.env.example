# ─── Base de datos ────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=
DB_NAME=facturacion_dte

# ─── App ──────────────────────────────────────────────────────────────────────
# Puerto del API NestJS. Por defecto 3002 para no chocar con otros servicios en :3000
PORT=3002
NODE_ENV=development

# URL pública del frontend (se usa en el QR del PDF para consulta por empresa)
APP_PUBLIC_URL=http://localhost:5173

# ─── Modo Demo ────────────────────────────────────────────────────────────────
# Si es "true", el sistema simula respuestas del MH sin conectarse a Hacienda.
# Útil para desarrollo local sin certificado ni credenciales reales.
MODO_DEMO=true

# ─── Ministerio de Hacienda — URLs ────────────────────────────────────────────
# Ambiente: 00=pruebas, 01=producción
MH_AMBIENTE=00

# Si ves ENOTFOUND / getaddrinfo: fallo de DNS o red.
# Verifica: dig apitest.dtes.mh.gob.sv — sin VPN bloqueante.
# DNS sugerido: 8.8.8.8 o 1.1.1.1
MH_AUTH_URL=https://apitest.dtes.mh.gob.sv/seguridad/auth
MH_API_URL=https://apitest.dtes.mh.gob.sv/fesv/recepciondte
MH_LOTE_URL=https://apitest.dtes.mh.gob.sv/fesv/recepcionlote
MH_LOTE_CONSULTA_URL=https://apitest.dtes.mh.gob.sv/fesv/recepcion/consultadtelote
MH_CONSULTA_URL=https://apitest.dtes.mh.gob.sv/fesv/recepcion/consultadte
MH_CONTINGENCIA_URL=https://apitest.dtes.mh.gob.sv/fesv/contingencia
MH_ANULAR_URL=https://apitest.dtes.mh.gob.sv/fesv/anulardte

# URL base del portal de consulta pública de Hacienda para el QR del PDF
MH_QR_BASE_URL=https://test7.mh.gob.sv/ssc/consulta/fe/

# ─── Firmador Docker (SVFE-API-Firmador) ──────────────────────────────────────
# URL del contenedor Docker oficial del MH para firmar documentos.
# Si no se configura, el sistema intentará firma local con el certificado .p12 de la empresa.
# En producción se recomienda el Docker del MH.
FIRMADOR_URL=http://localhost:8113

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_en_produccion_por_un_secret_largo_y_aleatorio
JWT_EXPIRES_IN=8h

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
# Para envío de confirmaciones de DTE a clientes
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=facturacion@tuempresa.com

# ─── Encryption ───────────────────────────────────────────────────────────────
# Clave para cifrar datos sensibles (contraseñas MH, certificados) en la BD
ENCRYPTION_KEY=una_clave_de_32_caracteres_aqui__

# ─── N1CO — Pagos y suscripciones ─────────────────────────────────────────────
N1CO_CLIENT_ID=
N1CO_CLIENT_SECRET=
N1CO_WEBHOOK_SECRET=
N1CO_LOCATION_ID=
# Sandbox:    https://api-sandbox.n1co.shop/api/v3
# Producción: https://api-pay.n1co.shop/api/v3
N1CO_API_URL=https://api-sandbox.n1co.shop/api/v3


# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL del frontend en producción (ej. https://app.tudominio.com)
FRONTEND_URL=http://localhost:5173

# ─── POS Integration ──────────────────────────────────────────────────────────
POS_API_KEY=cambia_esto_en_produccion
