# ══════════════════════════════════════════════════════
#  iFactu — Variables de entorno PRODUCCIÓN
#  Copiar como .env en /opt/ifactu/.env y completar
# ══════════════════════════════════════════════════════

# ── Aplicación ────────────────────────────────────────
NODE_ENV=production
PORT=3002

# ── Base de datos PostgreSQL ──────────────────────────
DB_HOST=host.docker.internal
DB_PORT=5432
DB_USER=ifactu_user
DB_PASS=CAMBIAR_POR_CLAVE_FUERTE
DB_NAME=ifactu_db

# ── JWT — generar con: openssl rand -base64 48 ────────
JWT_SECRET=CAMBIAR_POR_SECRET_LARGO_Y_ALEATORIO

# ── CORS ──────────────────────────────────────────────
FRONTEND_URL=https://ifactu.jsolutionsv.com

# ── Hacienda MH ───────────────────────────────────────
# Sandbox (pruebas):
MH_AMBIENTE=00
MH_API_URL=https://apitest.dtes.mh.gob.sv/fesv/recepciondte
MH_AUTH_URL=https://apitest.dtes.mh.gob.sv/seguridad/auth

# Producción (descomentar cuando estés listo):
# MH_AMBIENTE=01
# MH_API_URL=https://api.dtes.mh.gob.sv/fesv/recepciondte
# MH_AUTH_URL=https://api.dtes.mh.gob.sv/seguridad/auth

MH_NIT=COMPLETAR
MH_PASS_CERT=COMPLETAR

# ── N1CO pagos ────────────────────────────────────────
N1CO_API_URL=https://api.n1co.shop
N1CO_CLIENT_ID=COMPLETAR
N1CO_CLIENT_SECRET=COMPLETAR
N1CO_WEBHOOK_SECRET=COMPLETAR

# ── Email SMTP ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=COMPLETAR
SMTP_PASS=COMPLETAR
SMTP_FROM=noreply@ifactu.jsolutionsv.com

# ── WhatsApp (opcional) ───────────────────────────────
WHATSAPP_ENABLED=false
